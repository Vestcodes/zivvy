{
  "services": {
    "web": {
      "root": ".",
      "framework": "nextjs",
      "installCommand": "pnpm install --config.strict-dep-builds=false --config.verify-deps-before-run=false"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}
